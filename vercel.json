{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix painmap/client install",
  "buildCommand": "npm --prefix painmap/client run build",
  "outputDirectory": "painmap/client/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
